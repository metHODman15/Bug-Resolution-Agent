{
  "name": "build-agent",
  "displayName": "Build with Agent",
  "description": "White-label agentic build assistant — repo-driven via .github/ markdown files",
  "version": "3.0.0",
  "publisher": "ai-aether",
  "repository": {
    "type": "git",
    "url": "https://github.com/Akatsuki-Enterprises/Bug-Resolution-Agent"
  },
  "engines": {
    "vscode": "^1.99.0"
  },
  "categories": [
    "AI",
    "Chat",
    "Other"
  ],
  "extensionKind": [
    "ui",
    "workspace"
  ],
  "extensionDependencies": [],
  "activationEvents": [
    "onStartupFinished",
    "onChatParticipant:buildAgent.agent",
    "onView:buildAgent.chatView"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "chatParticipants": [
      {
        "id": "buildAgent.agent",
        "name": "agent",
        "fullName": "Build Agent",
        "description": "Agentic build assistant driven by repo configuration",
        "isSticky": true,
        "commands": [
          {
            "name": "reset",
            "description": "Clear the current session and start fresh"
          }
        ]
      }
    ],
    "languageModelTools": [
      {
        "name": "buildAgent_writeFile",
        "displayName": "Write File",
        "modelDescription": "Write content to a file inside the workspace.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "path": {
              "type": "string",
              "description": "Workspace-relative path to write"
            },
            "content": {
              "type": "string",
              "description": "File content to write"
            }
          },
          "required": [
            "path",
            "content"
          ]
        },
        "tags": [
          "file",
          "write"
        ]
      },
      {
        "name": "buildAgent_readFile",
        "displayName": "Read File",
        "modelDescription": "Read the contents of a file from the workspace.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "path": {
              "type": "string",
              "description": "Workspace-relative or absolute path to the file"
            }
          },
          "required": [
            "path"
          ]
        },
        "tags": [
          "file",
          "read"
        ]
      },
      {
        "name": "buildAgent_listDir",
        "displayName": "List Directory",
        "modelDescription": "List the contents of a directory in the workspace.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "path": {
              "type": "string",
              "description": "Workspace-relative or absolute directory path"
            }
          },
          "required": [
            "path"
          ]
        },
        "tags": [
          "file",
          "directory"
        ]
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "build-agent-activitybar",
          "title": "Build with Agent",
          "icon": "resources/sf-debug-icon.svg"
        }
      ]
    },
    "views": {
      "build-agent-activitybar": [
        {
          "type": "webview",
          "id": "buildAgent.chatView",
          "name": "Chat"
        }
      ]
    },
    "commands": [
      {
        "command": "buildAgent.newChat",
        "title": "New Chat",
        "category": "Build Agent"
      },
      {
        "command": "buildAgent.generateTemplates",
        "title": "Generate Agent Instructions",
        "category": "Build Agent"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint extension/src --ext ts",
    "test": "node ./out/test/runTest.js",
    "package:vsix": "npx vsce package -o extension.vsix"
  },
  "devDependencies": {
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.6",
    "@types/node": "^20.10.6",
    "@types/vscode": "^1.99.0",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "@vscode/test-electron": "^2.3.8",
    "eslint": "^8.56.0",
    "glob": "^10.3.10",
    "mocha": "^10.2.0",
    "typescript": "^5.3.3",
    "vsce": "^2.15.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.20.0",
    "openai": "^6.25.0"
  }
}
