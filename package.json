{
  "name": "sf-debug-agent",
  "displayName": "Salesforce Debug Agent",
  "description": "Copilot-native Salesforce debugging agent — autonomous investigation via @sfdebug in VS Code Chat",
  "version": "2.0.0",
  "publisher": "ai-aether",
  "repository": {
    "type": "git",
    "url": "https://github.com/Akatsuki-Enterprises/Bug-Resolution-Agent"
  },
  "engines": {
    "vscode": "^1.99.0"
  },
  "categories": [
    "AI",
    "Chat",
    "Debuggers",
    "Other"
  ],
  "extensionKind": [
    "ui",
    "workspace"
  ],
  "extensionDependencies": [],
  "activationEvents": [
    "onStartupFinished",
    "onChatParticipant:sfDebug.agent",
    "onView:sfDebug.chatView"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "chatParticipants": [
      {
        "id": "sfDebug.agent",
        "name": "sfdebug",
        "fullName": "Salesforce Debug Agent",
        "description": "Autonomously investigate and debug Salesforce issues",
        "isSticky": true,
        "commands": [
          {
            "name": "investigate",
            "description": "Start a new investigation. Provide org, symptom, object, and record IDs."
          },
          {
            "name": "approve",
            "description": "Approve the current investigation plan and run it"
          },
          {
            "name": "report",
            "description": "Generate the full report bundle (BU, Tech Document, Client)"
          },
          {
            "name": "reset",
            "description": "Clear the current investigation and start fresh"
          }
        ]
      }
    ],
    "languageModelTools": [
      {
        "name": "sfDebug_runSfCommand",
        "displayName": "Run SF CLI Command",
        "modelDescription": "Run a read-only Salesforce CLI command (sf data query, sf apex run, sf project retrieve start). Never runs deploy or DML. Returns stdout of the command.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "command": {
              "type": "string",
              "description": "The full SF CLI command to execute, e.g. sf data query --query \"SELECT Id FROM Account LIMIT 1\" --json --target-org myOrg"
            }
          },
          "required": [
            "command"
          ]
        },
        "tags": [
          "salesforce",
          "cli",
          "query"
        ]
      },
      {
        "name": "sfDebug_writeFile",
        "displayName": "Write File",
        "modelDescription": "Write content to a file inside the workspace. Allowed paths: runtime/scripts/, runtime/agent_workspace/, runtime/Reports/. Use this to save SOQL scripts, findings, and the final reports.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "path": {
              "type": "string",
              "description": "Workspace-relative path, e.g. runtime/Reports/2025-01-15-login-issue/BU.md"
            },
            "content": {
              "type": "string",
              "description": "File content to write"
            }
          },
          "required": [
            "path",
            "content"
          ]
        },
        "tags": [
          "file",
          "write"
        ]
      },
      {
        "name": "sfDebug_readFile",
        "displayName": "Read File",
        "modelDescription": "Read the contents of a file from the workspace.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "path": {
              "type": "string",
              "description": "Workspace-relative or absolute path to the file"
            }
          },
          "required": [
            "path"
          ]
        },
        "tags": [
          "file",
          "read"
        ]
      },
      {
        "name": "sfDebug_listDir",
        "displayName": "List Directory",
        "modelDescription": "List the contents of a directory in the workspace.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "path": {
              "type": "string",
              "description": "Workspace-relative or absolute directory path"
            }
          },
          "required": [
            "path"
          ]
        },
        "tags": [
          "file",
          "directory"
        ]
      }
    ],
    "viewsContainers": {
      "secondarySidebar": [
        {
          "id": "sf-debug-sidebar",
          "title": "SF Debug Agent",
          "icon": "resources/sf-debug-icon.svg"
        }
      ],
      "activitybar": [
        {
          "id": "sf-debug-activitybar",
          "title": "SF Debug Agent",
          "icon": "resources/sf-debug-icon.svg"
        }
      ]
    },
    "views": {
      "sf-debug-sidebar": [
        {
          "type": "webview",
          "id": "sfDebug.chatView",
          "name": "SF Debug Agent"
        }
      ],
      "sf-debug-activitybar": [
        {
          "type": "webview",
          "id": "sfDebug.chatView.activity",
          "name": "SF Debug Agent"
        }
      ]
    },
    "commands": [
      {
        "command": "sfDebug.configureApiKey",
        "title": "Configure API Key",
        "category": "SF Debug"
      }
    ],
    "configuration": {
      "title": "Salesforce Debug Agent",
      "properties": {
        "sfDebug.defaultOrgAlias": {
          "type": "string",
          "default": "",
          "description": "Default Salesforce org alias for investigations"
        },
        "sfDebug.maxRetryAttempts": {
          "type": "number",
          "default": 2,
          "description": "Maximum retry attempts before triggering loop-breaker"
        },
        "sfDebug.enableWebSearch": {
          "type": "boolean",
          "default": true,
          "description": "Enable web search when loop-breaker is triggered"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint extension/src --ext ts",
    "test": "node ./out/test/runTest.js",
    "package:vsix": "npx vsce package -o extension.vsix"
  },
  "devDependencies": {
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.6",
    "@types/node": "^20.10.6",
    "@types/vscode": "^1.99.0",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "@vscode/test-electron": "^2.3.8",
    "eslint": "^8.56.0",
    "glob": "^10.3.10",
    "mocha": "^10.2.0",
    "typescript": "^5.3.3",
    "vsce": "^2.15.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.20.0",
    "openai": "^6.25.0"
  }
}
