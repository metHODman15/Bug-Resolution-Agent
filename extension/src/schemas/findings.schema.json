{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Investigation Finding",
  "description": "Schema for investigation findings generated by the analyzer",
  "type": "object",
  "required": ["id", "type", "summary", "details", "evidence", "timestamp"],
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique identifier for the finding",
      "pattern": "^finding-.*"
    },
    "type": {
      "type": "string",
      "enum": ["data", "metadata", "permission", "automation", "web-research"],
      "description": "Category of the finding"
    },
    "summary": {
      "type": "string",
      "description": "Brief summary of the finding",
      "minLength": 10,
      "maxLength": 200
    },
    "details": {
      "type": "string",
      "description": "Detailed explanation of the finding",
      "minLength": 20
    },
    "evidence": {
      "type": "array",
      "description": "List of evidence supporting this finding",
      "items": {
        "type": "string"
      }
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "When this finding was generated"
    }
  }
}
