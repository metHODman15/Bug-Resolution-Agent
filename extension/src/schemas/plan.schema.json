{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Investigation Plan",
  "description": "Schema for investigation plans created by the planner",
  "type": "object",
  "required": ["id", "context", "steps", "approved", "createdAt"],
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique investigation identifier",
      "pattern": "^inv-.*"
    },
    "context": {
      "type": "object",
      "required": ["orgAlias", "symptom", "impactedObject", "impactedUsers", "exampleRecords", "timestamp", "investigationId"],
      "properties": {
        "orgAlias": {
          "type": "string",
          "description": "Target Salesforce org alias",
          "minLength": 1
        },
        "symptom": {
          "type": "string",
          "description": "Description of the issue",
          "minLength": 10
        },
        "impactedObject": {
          "type": "string",
          "description": "Salesforce object or feature affected",
          "minLength": 1
        },
        "impactedUsers": {
          "type": "string",
          "description": "Users or profiles affected"
        },
        "exampleRecords": {
          "type": "array",
          "description": "List of example record IDs or URLs",
          "minItems": 1,
          "maxItems": 10,
          "items": {
            "type": "string"
          }
        },
        "timestamp": {
          "type": "string",
          "format": "date-time"
        },
        "investigationId": {
          "type": "string"
        }
      }
    },
    "steps": {
      "type": "array",
      "description": "Investigation steps to execute",
      "minItems": 1,
      "maxItems": 15,
      "items": {
        "type": "object",
        "required": ["id", "type", "description", "status"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^step-.*"
          },
          "type": {
            "type": "string",
            "enum": ["query", "retrieve", "apex", "analysis"]
          },
          "description": {
            "type": "string",
            "minLength": 10
          },
          "command": {
            "type": "string",
            "description": "CLI command to execute"
          },
          "filePath": {
            "type": "string",
            "description": "Path to script file"
          },
          "status": {
            "type": "string",
            "enum": ["pending", "running", "completed", "failed"]
          },
          "output": {
            "type": "string",
            "description": "Command output"
          }
        }
      }
    },
    "approved": {
      "type": "boolean",
      "description": "Whether the plan has been approved for execution"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    }
  }
}
