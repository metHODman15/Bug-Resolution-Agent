-- Common SOQL Queries for Salesforce Investigations
-- These queries help identify field-level security and permission issues

-- Query 1: Field Permissions for a specific object and profile
SELECT 
    Id, 
    Parent.Profile.Name,
    SobjectType,
    Field,
    PermissionsEdit,
    PermissionsRead
FROM FieldPermissions
WHERE SobjectType = 'Account' 
  AND Field LIKE 'Account.%'
  AND Parent.ProfileId IN (
    SELECT ProfileId 
    FROM User 
    WHERE Username = 'user@example.com'
  )
ORDER BY Field

-- Query 2: Object Permissions
SELECT 
    Id,
    Parent.Profile.Name,
    SobjectType,
    PermissionsCreate,
    PermissionsRead,
    PermissionsEdit,
    PermissionsDelete,
    PermissionsViewAllRecords,
    PermissionsModifyAllRecords
FROM ObjectPermissions
WHERE SobjectType = 'Account'
  AND Parent.IsOwnedByProfile = true
ORDER BY Parent.Profile.Name

-- Query 3: User Permissions Summary
SELECT 
    Id,
    Username,
    Profile.Name,
    IsActive,
    UserType,
    LastLoginDate,
    Email
FROM User
WHERE Username = 'user@example.com'
LIMIT 1
